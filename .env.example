# ---- Google service account key (the whole JSON, on one line) ----
# From Google Cloud Console > IAM & Admin > Service Accounts > Keys > Add key (JSON).
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"...","client_email":"...@...iam.gserviceaccount.com"}

# ---- Shared secret that protects the endpoint ----
# Claude will call the server at:  https://YOUR-APP.onrender.com/mcp?token=THIS_VALUE
MCP_AUTH_TOKEN=replace-with-a-long-random-string

# PORT is supplied by Render automatically; locally it defaults to 3000.
